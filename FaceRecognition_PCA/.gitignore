FRG/faces/alan*.jpg
FRG/faces/alan*.jpeg
FRG/faces/alan*.png

# Augmentaciones generadas a partir de las selfies
FRG/faces/alan_aug/

# Dataset genérico de caras (s*.bmp) — también excluido por respeto a privacidad
FRG/faces/s*.bmp
FRG/faces/temp/

# Modelo PCA entrenado (codifica matemáticamente las caras de Alan)
FRG/data/eigen.txt
FRG/data/mean.txt
FRG/data/facesdata.txt

# Lista de entrenamiento (contiene rutas a fotos personales)
FRG/list/train_list.txt

# Mismos artefactos cuando ya están copiados a la app Android
